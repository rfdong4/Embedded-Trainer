#bug-hunt-layout {
    height: 1fr;
}

#code-panel {
    width: 1fr;
    padding: 1;
}

#answer-panel {
    width: 1fr;
    padding: 1;
}

#buggy-code {
    height: auto;
    max-height: 20;
    margin-bottom: 1;
}

#options {
    margin-bottom: 1;
}

#feedback-panel {
    height: 1fr;
    padding: 1;
    border: solid $accent;
}

#btn-submit {
    margin-top: 1;
    margin-bottom: 1;
}
